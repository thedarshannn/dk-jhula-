<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>

<!-- ============================================================
  ✏️ EDIT #1 — PAGE TITLE (shown in browser tab)
  Change "DK Jhula — Handcrafted with Love" to anything you want
============================================================ -->
<title>DK Jhula — Handcrafted with Love</title>

<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root {
  /* ============================================================
     ✏️ EDIT #2 — WEBSITE COLORS
     Change these color codes to update the whole website's look.
     --brown-dark  = main dark color (buttons, navbar)
     --gold        = accent/highlight color
     --cream       = page background
     Use any color codes from: https://htmlcolorcodes.com
  ============================================================ */
  --cream: #FAF6F0;
  --warm-white: #FDF9F4;
  --brown-dark: #3D1C08;
  --brown-mid: #6B3A1F;
  --brown-light: #A0622A;
  --gold: #C49A3C;
  --gold-light: #E8C97A;
  --beige: #E8DDD0;
  --beige-mid: #D4C4B0;
  --text-dark: #2C1505;
  --text-mid: #5A3820;
  --text-light: #9A7B60;
  --font-display: 'Cormorant Garamond', Georgia, serif;
  --font-body: 'Jost', sans-serif;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font-body); background: var(--cream); color: var(--text-dark); overflow-x: hidden; }

nav {
  position: sticky; top: 0; z-index: 100;
  background: var(--warm-white); border-bottom: 1px solid var(--beige);
  display: flex; align-items: center; justify-content: space-between; padding: 10px 40px;
}
.nav-logo { display: flex; align-items: center; gap: 12px; }
.nav-logo-img { width: 64px; height: 64px; border-radius: 50%; object-fit: cover; border: 2px solid var(--gold); }
.nav-brand-name { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--brown-dark); }
.nav-brand-owner { font-size: 11px; color: var(--text-light); font-style: italic; letter-spacing: 0.5px; }
.nav-brand-tag { font-size: 10px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }
.nav-links { display: flex; gap: 28px; list-style: none; }
.nav-links a { font-size: 12px; letter-spacing: 1.5px; text-transform: uppercase; color: var(--text-mid); text-decoration: none; transition: color 0.2s; }
.nav-links a:hover { color: var(--brown-dark); }
.btn-wa {
  display: flex; align-items: center; gap: 8px; background: #25D366; color: white;
  padding: 9px 18px; border-radius: 6px; font-size: 13px; font-weight: 500;
  text-decoration: none; letter-spacing: 0.5px; transition: opacity 0.2s;
}
.btn-wa:hover { opacity: 0.88; }
.btn-wa svg { width: 16px; height: 16px; }
.hero {
  min-height: 88vh; background: var(--warm-white);
  display: grid; grid-template-columns: 1fr 1fr;
  align-items: center; padding: 60px 40px 60px 60px; gap: 40px;
  position: relative; overflow: hidden;
}
.hero::before {
  content: ''; position: absolute; top: -60px; right: -60px;
  width: 500px; height: 500px; border-radius: 50%;
  background: var(--beige); opacity: 0.35; pointer-events: none;
}
.hero-left { position: relative; z-index: 1; }
.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--beige); border-radius: 20px; padding: 6px 16px; margin-bottom: 24px;
  font-size: 12px; letter-spacing: 2px; text-transform: uppercase; color: var(--brown-mid); font-weight: 500;
}
.hero-eyebrow::before { content: '✦'; color: var(--gold); }
.hero h1 { font-family: var(--font-display); font-size: 54px; font-weight: 600; line-height: 1.1; color: var(--brown-dark); margin-bottom: 10px; }
.hero h1 em { color: var(--gold); font-style: italic; }
.hero-owner { font-family: var(--font-display); font-size: 18px; font-style: italic; color: var(--text-light); margin-bottom: 16px; }
.hero-owner span { color: var(--gold); font-weight: 600; }
.hero-desc { font-size: 15px; color: var(--text-mid); line-height: 1.75; max-width: 440px; margin-bottom: 28px; }
.hero-stats { display: flex; gap: 32px; margin-bottom: 36px; }
.stat { text-align: center; }
.stat-num { font-family: var(--font-display); font-size: 32px; font-weight: 600; color: var(--brown-dark); line-height: 1; }
.stat-label { font-size: 11px; color: var(--text-light); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px; }
.hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
.btn-primary {
  padding: 14px 32px; background: var(--brown-dark); color: var(--gold-light);
  border: none; border-radius: 6px; font-family: var(--font-body); font-size: 13px;
  letter-spacing: 1.5px; text-transform: uppercase; font-weight: 500;
  cursor: pointer; text-decoration: none; transition: background 0.2s, transform 0.15s; display: inline-block;
}
.btn-primary:hover { background: var(--brown-mid); transform: translateY(-1px); }
.btn-outline {
  padding: 13px 28px; background: transparent; color: var(--brown-dark);
  border: 1.5px solid var(--brown-dark); border-radius: 6px; font-family: var(--font-body); font-size: 13px;
  letter-spacing: 1.5px; text-transform: uppercase; font-weight: 500;
  cursor: pointer; text-decoration: none; transition: all 0.2s; display: inline-block;
}
.btn-outline:hover { background: var(--brown-dark); color: var(--gold-light); }
.hero-right { position: relative; display: flex; justify-content: center; align-items: center; }
.hero-logo-frame {
  width: 400px; height: 400px; border-radius: 50%;
  border: 3px solid var(--gold); background: var(--cream);
  overflow: hidden; box-shadow: 0 16px 64px rgba(61,28,8,0.12);
}
.hero-logo-frame img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.hero-float-badge {
  position: absolute; bottom: 24px; left: -20px;
  background: var(--brown-dark); color: var(--gold-light);
  padding: 12px 20px; border-radius: 10px; font-size: 13px; font-weight: 500;
}
.hero-float-badge span { display: block; font-family: var(--font-display); font-size: 20px; font-weight: 600; color: var(--gold); }
.trust-bar { background: var(--brown-dark); display: flex; justify-content: center; flex-wrap: wrap; }
.trust-item { display: flex; align-items: center; gap: 10px; padding: 18px 28px; border-right: 1px solid rgba(255,255,255,0.1); color: var(--gold-light); }
.trust-item:last-child { border-right: none; }
.trust-icon { font-size: 20px; }
.trust-text strong { display: block; font-weight: 500; font-size: 13px; }
.trust-text span { color: rgba(232,201,122,0.65); font-size: 11px; }
.features-banner { background: var(--warm-white); padding: 40px; border-bottom: 1px solid var(--beige); }
.features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 24px; }
.feature-item { display: flex; align-items: flex-start; gap: 12px; }
.feature-icon { font-size: 26px; flex-shrink: 0; }
.feature-title { font-weight: 500; color: var(--brown-dark); font-size: 14px; margin-bottom: 3px; }
.feature-desc { font-size: 12px; color: var(--text-light); line-height: 1.5; }
section { padding: 72px 40px; }
.section-label { font-size: 11px; letter-spacing: 3px; text-transform: uppercase; color: var(--gold); font-weight: 500; margin-bottom: 10px; }
.section-title { font-family: var(--font-display); font-size: 40px; font-weight: 600; color: var(--brown-dark); line-height: 1.2; margin-bottom: 12px; }
.section-sub { font-size: 15px; color: var(--text-light); max-width: 560px; line-height: 1.7; }
.section-head { margin-bottom: 48px; }
.section-head.center { text-align: center; }
.section-head.center .section-sub { margin: 0 auto; }
.filter-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 36px; }
.filter-btn {
  padding: 8px 22px; border: 1.5px solid var(--beige-mid); border-radius: 30px;
  background: transparent; cursor: pointer; font-family: var(--font-body); font-size: 13px;
  color: var(--text-light); letter-spacing: 0.5px; transition: all 0.2s;
}
.filter-btn:hover, .filter-btn.active { background: var(--brown-dark); color: var(--gold-light); border-color: var(--brown-dark); }
.products-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 24px; }
.product-card {
  background: var(--warm-white); border: 1px solid var(--beige);
  border-radius: 14px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s;
}
.product-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(61,28,8,0.1); }
.product-img { height: 250px; position: relative; background: #fff; overflow: hidden; }
.product-img img { width: 100%; height: 100%; object-fit: contain; padding: 8px; }
.product-badge {
  position: absolute; top: 12px; left: 12px; z-index: 2;
  font-size: 11px; font-weight: 500; padding: 4px 12px; border-radius: 20px;
}
.badge-best { background: var(--gold); color: var(--brown-dark); }
.badge-new { background: #C8E6C9; color: #1B5E20; }
.badge-sale { background: #FFCDD2; color: #B71C1C; }
.product-body { padding: 16px 18px 20px; }
.product-name { font-family: var(--font-display); font-size: 17px; font-weight: 600; color: var(--brown-dark); margin-bottom: 5px; line-height: 1.3; }
.product-desc { font-size: 11px; color: var(--text-light); line-height: 1.5; margin-bottom: 14px; }
.product-footer { display: flex; align-items: center; justify-content: space-between; }
.product-price { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--brown-mid); }
.order-btn {
  padding: 8px 18px; background: var(--brown-dark); color: var(--gold-light);
  border: none; border-radius: 6px; cursor: pointer; font-family: var(--font-body);
  font-size: 12px; letter-spacing: 1px; text-transform: uppercase; font-weight: 500; transition: background 0.2s;
}
.order-btn:hover { background: var(--brown-mid); }
.about-section { background: var(--brown-dark); display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; padding: 72px 40px; }
.about-img { width: 100%; aspect-ratio: 1; border-radius: 50%; overflow: hidden; max-width: 360px; border: 3px solid var(--gold); }
.about-img img { width: 100%; height: 100%; object-fit: cover; }
.about-owner-tag { display: inline-block; background: rgba(196,154,60,0.15); border: 1px solid var(--gold); border-radius: 8px; padding: 10px 18px; margin-bottom: 20px; }
.about-owner-label { font-size: 10px; color: var(--gold); letter-spacing: 2px; text-transform: uppercase; }
.about-owner-name { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--gold-light); font-style: italic; }
.about-text { font-size: 15px; color: rgba(232,201,122,0.75); line-height: 1.8; margin-bottom: 18px; }
.about-highlight { font-family: var(--font-display); font-size: 22px; font-style: italic; color: var(--gold); margin-bottom: 28px; line-height: 1.4; }
.about-pills { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 32px; }
.about-pill { padding: 6px 16px; border: 1px solid var(--gold); border-radius: 20px; color: var(--gold-light); font-size: 12px; letter-spacing: 1px; }
.about-section .section-label { color: var(--gold); }
.about-section .section-title { color: var(--gold-light); }
.feedback-section { background: var(--warm-white); }
.feedback-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
.feedback-form-wrap { background: var(--cream); border: 1px solid var(--beige); border-radius: 16px; padding: 36px; }
.feedback-form-title { font-family: var(--font-display); font-size: 28px; font-weight: 600; color: var(--brown-dark); margin-bottom: 6px; }
.feedback-form-sub { font-size: 13px; color: var(--text-light); margin-bottom: 28px; }
.form-group { margin-bottom: 16px; }
.form-group label { display: block; font-size: 11px; letter-spacing: 1px; text-transform: uppercase; color: var(--text-mid); font-weight: 500; margin-bottom: 6px; }
.form-group input, .form-group textarea {
  width: 100%; padding: 11px 14px; border: 1.5px solid var(--beige-mid); border-radius: 8px;
  background: var(--warm-white); color: var(--text-dark); font-family: var(--font-body); font-size: 14px; outline: none; transition: border-color 0.2s;
}
.form-group input:focus, .form-group textarea:focus { border-color: var(--gold); }
.form-group textarea { resize: vertical; min-height: 100px; }
.star-select { display: flex; gap: 6px; margin-bottom: 16px; }
.star-select span { font-size: 30px; cursor: pointer; color: var(--beige-mid); transition: color 0.15s; user-select: none; }
.star-select span.active { color: var(--gold); }
.form-submit {
  width: 100%; padding: 14px; background: var(--brown-dark); color: var(--gold-light);
  border: none; border-radius: 8px; font-family: var(--font-body); font-size: 13px;
  letter-spacing: 1.5px; text-transform: uppercase; font-weight: 500; cursor: pointer; transition: background 0.2s;
}
.form-submit:hover { background: var(--brown-mid); }
.form-success { display: none; text-align: center; padding: 16px; background: #E8F5E9; border: 1px solid #A5D6A7; border-radius: 8px; color: #2E7D32; font-size: 14px; margin-top: 16px; }
.feedbacks-list-title { font-family: var(--font-display); font-size: 28px; font-weight: 600; color: var(--brown-dark); margin-bottom: 4px; }
.feedbacks-count { font-size: 13px; color: var(--text-light); margin-bottom: 24px; }
.feedbacks-list { display: flex; flex-direction: column; gap: 14px; max-height: 560px; overflow-y: auto; padding-right: 4px; }
.feedbacks-list::-webkit-scrollbar { width: 4px; }
.feedbacks-list::-webkit-scrollbar-thumb { background: var(--beige-mid); border-radius: 4px; }
.feedback-card { background: var(--cream); border: 1px solid var(--beige); border-radius: 12px; padding: 20px; }
.feedback-card-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.feedback-author { font-weight: 500; color: var(--brown-dark); font-size: 14px; }
.feedback-product { font-size: 11px; color: var(--text-light); margin-top: 2px; }
.feedback-stars { color: var(--gold); font-size: 14px; }
.feedback-text { font-size: 13px; color: var(--text-mid); line-height: 1.6; font-style: italic; }
.feedback-date { font-size: 11px; color: var(--text-light); margin-top: 8px; }
.no-feedback { text-align: center; padding: 40px 20px; color: var(--text-light); font-size: 14px; font-style: italic; }
.order-section { background: var(--beige); text-align: center; padding: 72px 40px; }
.order-cards { display: flex; justify-content: center; gap: 20px; flex-wrap: wrap; margin-top: 40px; }
.order-card { background: var(--warm-white); border: 1px solid var(--beige-mid); border-radius: 14px; padding: 28px 32px; min-width: 200px; text-align: center; text-decoration: none; transition: transform 0.2s, box-shadow 0.2s; }
.order-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
.order-card-icon { font-size: 32px; margin-bottom: 10px; }
.order-card-title { font-weight: 500; color: var(--brown-dark); margin-bottom: 4px; }
.order-card-sub { font-size: 13px; color: var(--text-light); }
footer { background: var(--text-dark); padding: 40px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px; }
.footer-logo-wrap { display: flex; align-items: center; gap: 14px; }
.footer-logo-img { width: 52px; height: 52px; border-radius: 50%; object-fit: cover; border: 1.5px solid var(--gold); }
.footer-brand { font-family: var(--font-display); font-size: 22px; color: var(--gold-light); font-weight: 600; }
.footer-brand span { color: var(--gold); }
.footer-owner { font-size: 12px; color: rgba(232,201,122,0.6); font-style: italic; margin-top: 2px; }
.footer-tagline { font-size: 11px; color: rgba(232,201,122,0.4); margin-top: 2px; letter-spacing: 1px; }
.footer-links { display: flex; gap: 24px; }
.footer-links a { font-size: 13px; color: rgba(232,201,122,0.55); text-decoration: none; letter-spacing: 1px; }
.footer-links a:hover { color: var(--gold-light); }
.footer-copy { font-size: 12px; color: rgba(232,201,122,0.35); }
.toast { position: fixed; bottom: 24px; right: 24px; background: var(--brown-dark); color: var(--gold-light); padding: 14px 24px; border-radius: 8px; font-size: 14px; border: 1px solid var(--gold); opacity: 0; pointer-events: none; transform: translateY(8px); transition: all 0.3s; z-index: 999; }
.toast.show { opacity: 1; transform: translateY(0); }
@media (max-width: 768px) {
  nav { padding: 10px 20px; }
  .nav-links { display: none; }
  .hero { grid-template-columns: 1fr; padding: 40px 20px; min-height: auto; }
  .hero-right { display: none; }
  .hero h1 { font-size: 36px; }
  section { padding: 48px 20px; }
  .about-section { grid-template-columns: 1fr; padding: 48px 20px; }
  .about-img { display: none; }
  .feedback-grid { grid-template-columns: 1fr; }
  .features-banner { padding: 28px 20px; }
  footer { flex-direction: column; text-align: center; padding: 32px 20px; }
  .trust-item { padding: 14px 16px; }
}
</style>
</head>
<body>

<!-- ============================================================
  ✏️ EDIT #3 — NAVBAR LOGO IMAGE
  Replace "logo_png.jpg" with your logo file name.
  Make sure your logo file is in the SAME FOLDER as index.html!
  Example: src="my_logo.png" or src="dk_logo.jpg"
============================================================ -->
<nav>
  <div class="nav-logo">
    <img class="nav-logo-img" src="logo_png.jpg" alt="DK Jhula Logo"/>
    <div>
      <!-- ✏️ EDIT #4 — BUSINESS NAME in navbar -->
      <div class="nav-brand-name">DK Jhula</div>
      <!-- ✏️ EDIT #5 — OWNER NAME in navbar -->
      <div class="nav-brand-owner">by Daxaben K. Prajapati</div>
      <!-- ✏️ EDIT #6 — TAGLINE in navbar -->
      <div class="nav-brand-tag">Handcrafted with Love</div>
    </div>
  </div>
  <ul class="nav-links">
    <li><a href="#shop">Shop</a></li>
    <li><a href="#about">About</a></li>
    <li><a href="#feedback">Reviews</a></li>
    <li><a href="#order">Order</a></li>
  </ul>
  <div>
    <!-- ✏️ EDIT #7 — WHATSAPP BUTTON in navbar
         Replace 916351551471 with: 91 + your 10-digit number
         Example: 919876543210 -->
    <a class="btn-wa" href="https://wa.me/916351551471" target="_blank">
      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp Order
    </a>
  </div>
</nav>

<!-- ============================================================
  ✏️ EDIT #8 — HERO SECTION (Big banner at top of page)
  This is the first thing visitors see!
============================================================ -->
<section class="hero">
  <div class="hero-left">
    <!-- ✏️ EDIT #9 — Small badge text above headline -->
    <div class="hero-eyebrow">Handcrafted in India</div>

    <!-- ✏️ EDIT #10 — MAIN HEADLINE
         The word inside <em>...</em> appears in gold italic -->
    <h1>Beautiful<br><em>Jhulas</em> &<br>Home Decor</h1>

    <!-- ✏️ EDIT #11 — Owner name shown below headline -->
    <p class="hero-owner">by <span>Daxaben K. Prajapati</span></p>

    <!-- ✏️ EDIT #12 — SHORT DESCRIPTION under headline -->
    <p class="hero-desc">Each piece is handcrafted using premium resham doori — washable, strong, with warranty. From royal canopy jhulas to baby cradles and artisan décor. Customize colour, design & size. Ships worldwide.</p>

    <!-- ✏️ EDIT #13 — STATS (numbers shown under description) -->
    <div class="hero-stats">
      <div class="stat">
        <div class="stat-num">15+</div>        <!-- Change number here -->
        <div class="stat-label">Years Experience</div>  <!-- Change label here -->
      </div>
      <div class="stat">
        <div class="stat-num">70+</div>         <!-- Change number here -->
        <div class="stat-label">Happy Customers</div>
      </div>
      <div class="stat">
        <div class="stat-num">5+</div>          <!-- Change number here -->
        <div class="stat-label">Countries Served</div>
      </div>
    </div>

    <div class="hero-btns">
      <a href="#shop" class="btn-primary">Shop Now</a>
      <!-- ✏️ EDIT #14 — WhatsApp number in Custom Order button -->
      <a href="https://wa.me/916351551471" target="_blank" class="btn-outline">Custom Order</a>
    </div>
  </div>

  <div class="hero-right">
    <!-- ✏️ EDIT #15 — HERO IMAGE (right side of banner)
         Replace "logo_png.jpg" with any product photo file name -->
    <div class="hero-logo-frame">
      <img src="logo_png.jpg" alt="DK Jhula"/>
    </div>
    <!-- ✏️ EDIT #16 — Floating badge on hero image -->
