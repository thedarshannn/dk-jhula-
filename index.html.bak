</section>

<!-- ============================================================
  ✏️ EDIT #20 — ABOUT SECTION
  Change your story, name, description text here
============================================================ -->
<section class="about-section" id="about">
  <!-- ✏️ EDIT #21 — ABOUT IMAGE
       Replace "logo_png.jpg" with your own photo if you want -->
  <div class="about-img"><img src="logo_png.jpg" alt="DK Jhula"/></div>
  <div>
    <div class="section-label">Our Story</div>
    <!-- ✏️ EDIT #22 — About section heading -->
    <div class="section-title">DK Jhula —<br>A Home Business<br>Built on Craft</div>
    <div class="about-owner-tag">
      <div class="about-owner-label">Owner &amp; Artisan</div>
      <!-- ✏️ EDIT #23 — Owner name in about section -->
      <div class="about-owner-name">Daxaben K. Prajapati</div>
    </div>
    <!-- ✏️ EDIT #24 — About paragraphs. Change your story here -->
    <p class="about-text">DK Jhula is a small home-based business run with passion from Anand, Gujarat. Every jhula and home decor item is handcrafted using premium resham doori — no factory, no machines. Just skilled hands, a loving heart, and 15+ years of experience.</p>
    <p class="about-text">All products are fully washable and come with a rope warranty. We customize colour, design, and size for any order. Our jhulas hold 150–200 kg and are safe for all ages — from babies to grandparents.</p>
    <!-- ✏️ EDIT #25 — Quote / highlight text -->
    <div class="about-highlight">"More than 15 years of craft,<br>delivered to your doorstep."</div>
    <!-- ✏️ EDIT #26 — Pill/tag badges. Add or remove <div class="about-pill"> lines -->
    <div class="about-pills">
      <div class="about-pill">15+ Years Experience</div>
      <div class="about-pill">Resham Doori</div>
      <div class="about-pill">5+ Countries</div>
      <div class="about-pill">Fully Washable</div>
      <div class="about-pill">Rope Warranty</div>
      <div class="about-pill">Custom Orders Welcome</div>
    </div>
    <!-- ✏️ EDIT #27 — WhatsApp number in About button -->
    <a href="https://wa.me/916351551471" class="btn-primary" target="_blank">Chat for product </a>
  </div>
</section>

<!-- ============================================================
  REVIEWS SECTION — customers can submit reviews live on the page
  No editing needed here. Reviews are submitted by customers.
============================================================ -->
<section class="feedback-section" id="feedback">
  <div class="section-head center">
    <div class="section-label">Customer Love</div>
    <div class="section-title">Reviews & Feedback</div>
    <div class="section-sub">Loved your DK Jhula? Share your experience — it inspires us and helps other customers too!</div>
  </div>
  <div class="feedback-grid">
    <div class="feedback-form-wrap">
      <div class="feedback-form-title">Leave a Review</div>
      <div class="feedback-form-sub">Your name and email are required. Email will be shown partially for privacy.</div>
      <div class="form-group"><label>Your Name *</label><input type="text" id="fb-name" placeholder="e.g. Priya Sharma"/></div>
      <div class="form-group"><label>Email Address *</label><input type="email" id="fb-email" placeholder="your@email.com"/></div>
      <div class="form-group"><label>Product Purchased (optional)</label><input type="text" id="fb-product" placeholder="e.g. Pink Canopy Jhula"/></div>
      <div class="form-group">
        <label>Your Rating</label>
        <div class="star-select" id="star-select">
          <span onclick="setRating(1)">★</span><span onclick="setRating(2)">★</span>
          <span onclick="setRating(3)">★</span><span onclick="setRating(4)">★</span>
          <span onclick="setRating(5)">★</span>
        </div>
      </div>
      <div class="form-group"><label>Your Feedback *</label><textarea id="fb-text" placeholder="Tell us about quality, delivery, customization experience..."></textarea></div>
      <button class="form-submit" onclick="submitFeedback()">Submit Feedback</button>
      <div class="form-success" id="form-success">🙏 Thank you! Your feedback means the world to us.</div>
    </div>
    <div>
      <div class="feedbacks-list-title">Customer Reviews</div>
      <div class="feedbacks-count" id="feedbacks-count">Be the first to leave a review!</div>
      <div class="feedbacks-list" id="feedbacks-list">
        <div class="no-feedback" id="no-feedback">No reviews yet. Share yours above! 🌟</div>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
