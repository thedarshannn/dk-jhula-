<!-- ============================================================
  ✏️ EDIT #32 — FOOTER
  Update business name, owner name, year established
============================================================ -->
<footer>
  <div class="footer-logo-wrap">
    <!-- ✏️ EDIT #33 — Footer logo image file name -->
    <img class="footer-logo-img" src="logo_png.jpg" alt="DK Jhula"/>
    <div>
      <div class="footer-brand">DK <span>Jhula</span></div>
      <div class="footer-owner">by Daxaben K. Prajapati</div>
      <!-- ✏️ EDIT #34 — Year established -->
      <div class="footer-tagline">Handcrafted with Love · Est. 2009</div>
    </div>
  </div>
  <div class="footer-links">
    <a href="#shop">Shop</a><a href="#about">About</a><a href="#feedback">Reviews</a><a href="#order">Contact</a>
  </div>
  <!-- ✏️ EDIT #35 — Copyright year and business name -->
  <div class="footer-copy">© 2026 DK Jhula. All rights reserved.</div>
</footer>

<div class="toast" id="toast">✓ Opening WhatsApp to place your order!</div>

<script>
// ============================================================
// ✏️ EDIT #36 — YOUR WHATSAPP NUMBER
// Replace 916351551471 with 91 + your 10-digit number
// Example: 919876543210
// ============================================================
const WHATSAPP = "916351551471";

// ============================================================
// ✏️ EDIT #37 — COMMON PRODUCT DESCRIPTION
// This D variable is used as default description for jhulas.
// Change it to match your standard features.
// ============================================================
const D = "Resham doori • Washable • Warranty • 150–200kg capacity • Customize colour, size & design";

// ============================================================
// ✏️ EDIT #19 — ADD YOUR PRODUCTS HERE
//
// HOW TO ADD A NEW PRODUCT:
// Copy one block from { to }, paste it after the last one,
// add a comma after the previous product's closing }
//
// FIELDS:
//   name   = Product name shown on card
//   desc   = Short description (or use D for the standard one)
//   price  = Price shown e.g. "₹2,999"
//   img    = Your photo filename e.g. "p1.jpg"
//            ⚠️ Photo must be in the SAME FOLDER as index.html!
//   badge  = "best" (gold) | "new" (green) | "sale" (red) | "" (none)
//   cat    = "jhula" | "baby" | "decor"
//            (must match the filter buttons above)
//
// HOW TO REMOVE A PRODUCT: Delete from { to }, including the comma
// HOW TO CHANGE PRICE: Just change the "₹..." text
// HOW TO CHANGE PHOTO: Change the "p1.jpg" to your new file name
// ============================================================
const products = [
  { name: "Royal Canopy Jhula — Pink & White",        desc: D,   price: "₹4,500",  img: "p1.jpg",  badge: "best", cat: "jhula" },
  { name: "Round Macramé Swing — Pink",               desc: D,   price: "₹2,999",  img: "p2.jpg",  badge: "new",  cat: "jhula" },
  { name: "Luxury Round Daybed Swing — Red",          desc: D,   price: "₹12,650", img: "p3.jpg",  badge: "best", cat: "jhula" },
  { name: "Baby Sleeping Jhula",                      desc: "Natural cotton • Wooden bead accents • Soft & safe for infants • Washable • Warranty", price: "₹3,999", img: "p4.jpg", badge: "best", cat: "baby" },
  { name: "Boho Canopy Swing — Cream (Open)",         desc: D,   price: "₹9,500",  img: "p5.jpg",  badge: "new",  cat: "jhula" },
  { name: "Boho Canopy Swing — Cream (Closed)",       desc: D,   price: "₹9,500",  img: "p6.jpg",  badge: "",     cat: "jhula" },
  { name: "Rust Canopy Daybed Swing",                 desc: D,   price: "₹9,900",  img: "p7.jpg",  badge: "best", cat: "jhula" },
  { name: "Cone Net Swing — Forest Green",            desc: D,   price: "₹3,560",  img: "p8.jpg",  badge: "new",  cat: "jhula" },
  { name: "Royal Canopy Chair — Black & Gold",        desc: D,   price: "₹2,500",  img: "p9.jpg",  badge: "sale", cat: "jhula" },
  { name: "Bell Jhula — Hot Pink",                    desc: D,   price: "₹4,100",  img: "p10.jpg", badge: "new",  cat: "jhula" },
  { name: "Kids Square Swing — Blue & White",         desc: D,   price: "₹2,800",  img: "p11.jpg", badge: "new",  cat: "jhula" },
  { name: "Macramé Ganesha Wall Art",                 desc: "Handknotted resham rope • Unique home décor • Customizable size & colour", price: "₹350", img: "p12.jpg", badge: "best", cat: "decor" },
];
// ============================================================
// END OF PRODUCTS — do not edit below this line
// ============================================================

function renderProducts(items) {
  document.getElementById('products-grid').innerHTML = items.map(p => `
    <div class="product-card">
      <div class="product-img">
        ${p.badge ? `<div class="product-badge badge-${p.badge}">${p.badge==='best'?'Bestseller':p.badge==='new'?'New':'Sale'}</div>` : ''}
        <img src="${p.img}" alt="${p.name}" loading="lazy"/>
      </div>
      <div class="product-body">
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <div class="product-price">${p.price}</div>
          <button class="order-btn" onclick="orderProduct('${p.name}','${p.price}')">Order</button>
        </div>
      </div>
    </div>`).join('');
}

function filterProducts(btn, cat) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(cat === 'all' ? products : products.filter(p => p.cat === cat));
}

function orderProduct(name, price) {
  const msg = encodeURIComponent(`Hi DK Jhula! 🙏\nI'd like to order:\n*${name}* (${price})\nPlease share availability, customization options & delivery details.`);
  window.open(`https://wa.me/${WHATSAPP}?text=${msg}`, '_blank');
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3000);
}

let feedbacks = [];
let selectedRating = 5;
window.onload = () => { setRating(5); };

function setRating(n) {
  selectedRating = n;
  document.querySelectorAll('#star-select span').forEach((s, i) => s.classList.toggle('active', i < n));
}

function submitFeedback() {
  const name = document.getElementById('fb-name').value.trim();
  const email = document.getElementById('fb-email').value.trim();
  const product = document.getElementById('fb-product').value.trim();
  const text = document.getElementById('fb-text').value.trim();
  if (!name) { alert('Please enter your name.'); return; }
  if (!email || !email.includes('@')) { alert('Please enter a valid email.'); return; }
  if (!text) { alert('Please write your feedback.'); return; }
  feedbacks.unshift({
    name, product, rating: selectedRating, text,
    email: email.replace(/(.{2})(.*)(@.*)/, (_, a, b, c) => a + b.replace(/./g,'*') + c),
    date: new Date().toLocaleDateString('en-IN', { day:'numeric', month:'long', year:'numeric' })
  });
  document.getElementById('fb-name').value = '';
  document.getElementById('fb-email').value = '';
  document.getElementById('fb-product').value = '';
  document.getElementById('fb-text').value = '';
  setRating(5);
  const s = document.getElementById('form-success');
  s.style.display = 'block';
  setTimeout(() => s.style.display = 'none', 4000);
  renderFeedbacks();
}

function renderFeedbacks() {
  const list = document.getElementById('feedbacks-list');
  const count = document.getElementById('feedbacks-count');
  if (!feedbacks.length) {
    list.innerHTML = '<div class="no-feedback">No reviews yet. Share yours! 🌟</div>';
    count.textContent = 'Be the first to leave a review!';
    return;
  }
  count.textContent = `${feedbacks.length} review${feedbacks.length > 1 ? 's' : ''} from our customers`;
  list.innerHTML = feedbacks.map(f => `
    <div class="feedback-card">
      <div class="feedback-card-header">
        <div>
          <div class="feedback-author">${f.name}</div>
          ${f.product ? `<div class="feedback-product">Purchased: ${f.product}</div>` : ''}
        </div>
        <div class="feedback-stars">${'★'.repeat(f.rating)}${'☆'.repeat(5-f.rating)}</div>
      </div>
      <div class="feedback-text">"${f.text}"</div>
      <div class="feedback-date">${f.date} · ${f.email}</div>
    </div>`).join('');
}

renderProducts(products);
</script>
</body>
</html>
