    <button class="filter-btn" onclick="filterProducts(this,'jhula')">Jhulas &amp; Swings</button>
    <button class="filter-btn" onclick="filterProducts(this,'baby')">Baby Jhula</button>
    <button class="filter-btn" onclick="filterProducts(this,'decor')">Home Decor</button>
  </div>
